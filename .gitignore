# ── macOS metadata ────────────────────────────────────────────────────────────
.DS_Store
._.DS_Store
._*

# ── Local renv library ────────────────────────────────────────────────────────
renv/library/
renv/staging/
renv/sandbox/
renv/local/

# ── Large binary data files (served from host, not tracked in git) ────────────
**/*.h5
**/*.crb

# ── Credentials / secrets ─────────────────────────────────────────────────────
**/*.sqlite

# ── Cached / generated runtime data (not source code) ────────────────────────
**/*.qs
apps/btki/data/

# ── R session artifacts ───────────────────────────────────────────────────────
.Rhistory
.RData
.Rproj.user/
*.Rproj
